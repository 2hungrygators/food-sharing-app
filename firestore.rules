rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid (string), displayName (string), photoURL (string), bio (string), streak (int), longestStreak (int), lastPostDate (timestamp), totalLikes (int), totalDislikes (int), createdAt (timestamp)
    //
    // Collection: posts
    // Fields: authorUid (string), authorName (string), authorPhoto (string), imageUrl (string), tag (string), mood (string), caption (string), likeCount (int), dislikeCount (int), createdAt (timestamp), groupId (string)
    //
    // Collection: posts/{postId}/reactions
    // Fields: type (string), userUid (string), createdAt (timestamp)
    //
    // Collection: users/{userId}/following
    // Fields: followerUid (string), followingUid (string), createdAt (timestamp)
    //
    // Collection: groups
    // Fields: name (string), adminUid (string), members (list), createdAt (timestamp)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "amshu.chitrakar@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             (data.photoURL == null || isValidUrl(data.photoURL)) &&
             (data.bio == null || (data.bio is string && data.bio.size() < 280));
    }

    function isValidPost(data) {
      return data.authorUid == request.auth.uid &&
             data.tag in ['Breakfast', 'Lunch', 'Dinner', 'Snack'] &&
             data.mood in ['happy', 'neutral', 'sad'] &&
             isValidUrl(data.imageUrl) &&
             (data.caption == null || (data.caption is string && data.caption.size() <= 280));
    }

    function isValidReaction(data) {
      return data.userUid == request.auth.uid &&
             data.type in ['like', 'dislike'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /following/{targetUserId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) && request.resource.data.followerUid == userId;
      }
      
      match /followers/{targetUserId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    function isValidCounterUpdate() {
      // Allow updating ONLY likeCount or dislikeCount by exactly 1
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['likeCount']) || affectedKeys.hasOnly(['dislikeCount']);
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        // Author can edit within 15 mins
        (resource.data.authorUid == request.auth.uid && 
         request.time < resource.data.createdAt + duration.value(15, 'm') &&
         isValidPost(request.resource.data)) ||
        // Others can only update counters
        isValidCounterUpdate()
      );
      allow delete: if isAuthenticated() && 
                    resource.data.authorUid == request.auth.uid && 
                    request.time < resource.data.createdAt + duration.value(15, 'm');

      match /reactions/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId) && isValidReaction(request.resource.data);
      }
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.members);
      allow create: if isAuthenticated() && request.resource.data.adminUid == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.members);
    }
  }
}
